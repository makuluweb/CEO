const SYSTEM = "You are a strategic advisor to a senior KPMG partner who leads Mining, Energy & Utilities. Be direct, insightful, and provocative in the style of Steve Bartlett from Diary of a CEO. Avoid corporate jargon. Be concise and human.";

// ── API Call ─────────────────────────────────────────────────────────────
async function callClaude(prompt, systemPrompt, apiKey, onResult) {
const res = await fetch("https://api.anthropic.com/v1/messages", {
method: "POST",
headers: {
"Content-Type": "application/json",
"x-api-key": apiKey,
"anthropic-version": "2023-06-01",
"anthropic-dangerous-direct-browser-access": "true",
},
body: JSON.stringify({
model: "claude-sonnet-4-5",
max_tokens: 1000,
system: systemPrompt || SYSTEM,
messages: [{ role: "user", content: prompt }],
}),
});

if (!res.ok) {
const errText = await res.text().catch(() => "no body");
throw new Error(`API ${res.status}: ${errText}`);
}
const data = await res.json();
if (data.error) throw new Error(data.error.message || JSON.stringify(data.error));
const text = data.content?.map(b => b.text || "").join("") || "";
if (!text) throw new Error("Empty response from API");
onResult(text);
return text;
}

